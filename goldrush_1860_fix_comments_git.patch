+//Input: currentPlayer index, steps from spinner/action movement
+//Output: selected 1860 destination tile id or original tile id if cancelled/no move exists
+//Purpose: lets a human choose where to move on the 1860 free-movement board
+//Relation: called by takeMovementSpin when boardViewMode is Mode1860
+int Game::chooseMode1860Destination(int currentPlayer, int steps) {
+    Player& player = players[static_cast<std::size_t>(currentPlayer)];
+    if (!board.isMode1860TileId(player.tile)) {
+        player.tile = board.mode1860StartTileId();
+    }
+
+    const std::vector<int> reachable = reachableMode1860Destinations(player.tile, steps);
+    if (reachable.empty()) {
+        showInfoPopup("1860 Movement", "No legal forward destination for this spin.");
+        return player.tile;
+    }
+
+    int cursorTile = reachable.front();
+    keypad(boardWin, TRUE);
+    while (true) {
+        board.render1860Selection(boardWin,
+                                  players,
+                                  currentPlayer,
+                                  cursorTile,
+                                  reachable,
+                                  steps,
+                                  hasColor);
+        werase(msgWin);
+        drawBoxSafe(msgWin);
+        mvwprintw(msgWin,
+                  1,
+                  2,
+                  "%s",
+                  "Choose highlighted 1860 tile: arrows/WASD move, Enter confirms, Esc cancels.");
+        const Tile& cursor = board.tileAt(cursorTile);
+        mvwprintw(msgWin,
+                  2,
+                  2,
+                  "Cursor: Space %d - %s | Goal: retirement is in the top-right.",
+                  cursorTile,
+                  getTileDisplayName(cursor).c_str());
+        wrefresh(msgWin);
+
+        const int ch = wgetch(boardWin);
+        if (ch == '\n' || ch == '\r' || ch == KEY_ENTER) {
+            return cursorTile;
+        }
+        if (ch == 27 || ch == 'q' || ch == 'Q') {
+            showInfoPopup("1860 Movement", "Movement cancelled.");
+            return player.tile;
+        }
+
+        int nextCursor = cursorTile;
+        if (ch == KEY_UP || ch == 'w' || ch == 'W') {
+            nextCursor = chooseNearest1860Cursor(board, reachable, cursorTile, -1, 0);
+        } else if (ch == KEY_DOWN || ch == 's' || ch == 'S') {
+            nextCursor = chooseNearest1860Cursor(board, reachable, cursorTile, 1, 0);
+        } else if (ch == KEY_LEFT || ch == 'a' || ch == 'A') {
+            nextCursor = chooseNearest1860Cursor(board, reachable, cursorTile, 0, -1);
+        } else if (ch == KEY_RIGHT || ch == 'd' || ch == 'D') {
+            nextCursor = chooseNearest1860Cursor(board, reachable, cursorTile, 0, 1);
+        } else if (ch == '\t' || ch == 'n' || ch == 'N') {
+            const std::vector<int>::const_iterator it = std::find(reachable.begin(), reachable.end(), cursorTile);
+            const std::size_t index = it == reachable.end() ? 0 : static_cast<std::size_t>(it - reachable.begin());
+            nextCursor = reachable[(index + 1) % reachable.size()];
+        }
+        cursorTile = nextCursor;
+    }
+}
+
+//Input: currentPlayer index, steps from spinner/action movement
+//Output: selected legal 1860 destination tile id or original tile id if no move exists
+//Purpose: gives CPU and forced 1860 movement a deterministic forward destination
+//Relation: used when a human picker is not appropriate
+int Game::chooseAutomatic1860Destination(int currentPlayer, int steps) const {
+    const Player& player = players[static_cast<std::size_t>(currentPlayer)];
+    if (!board.isMode1860TileId(player.tile)) {
+        return board.mode1860StartTileId();
+    }
+
+    const std::vector<int> reachable = reachableMode1860Destinations(player.tile, steps);
+    if (reachable.empty()) {
+        return player.tile;
+    }
+
+    const int retirementTile = board.mode1860RetirementTileId();
+    if (std::find(reachable.begin(), reachable.end(), retirementTile) != reachable.end()) {
+        return retirementTile;
+    }
+
+    return *std::max_element(reachable.begin(), reachable.end(), [&](int a, int b) {
+        const Tile& tileA = board.tileAt(a);
+        const Tile& tileB = board.tileAt(b);
+        const int progressA = (board.mode1860Rows() - 1 - tileA.mode1860Y) + tileA.mode1860X;
+        const int progressB = (board.mode1860Rows() - 1 - tileB.mode1860Y) + tileB.mode1860X;
+        if (progressA != progressB) {
+            return progressA < progressB;
+        }
+        return a < b;
+    });
+}
+
+//Input: currentPlayer index, destination 1860 tile id
+//Output: bool indicating whether a STOP tile effect was resolved
+//Purpose: moves directly to a selected 1860 tile because 1860 tiles do not use classic next links
+//Relation: replaces animateMove for Mode1860 movement
+bool Game::applyMode1860Movement(int currentPlayer, int destinationTile) {
+    Player& player = players[static_cast<std::size_t>(currentPlayer)];
+    if (!board.isMode1860TileId(destinationTile) || destinationTile == player.tile) {
+        return false;
+    }
+
+    player.tile = destinationTile;
+    const Tile& landed = board.tileAt(player.tile);
+    renderGame(currentPlayer,
+               player.name + " moved to " + getTileDisplayName(landed),
+               "1860 movement completed. Goal: reach Retirement in the top-right.");
+    napms(250);
+    checkTrapTrigger(currentPlayer);
+
+    const Tile& afterTrap = board.tileAt(player.tile);
+    if (board.isStopSpace(afterTrap)) {
+        applyTileEffect(currentPlayer, afterTrap);
+        return true;
+    }
+    return false;
+}
