+//Input: fromTileId (current 1860 tile id), steps (movement amount)
+//Output: vector of reachable 1860 destination tile ids
+//Purpose: finds 1860 moves that use grid distance while keeping progress toward retirement
+//Relation: used by human selection, CPU movement, and action-card movement on the 1860 board
+std::vector<int> Game::reachableMode1860Destinations(int fromTileId, int steps) const {
+    std::vector<int> destinations;
+    if (!board.isMode1860TileId(fromTileId) || steps <= 0) {
+        return destinations;
+    }
+
+    const Tile& from = board.tileAt(fromTileId);
+    const int startProgress = (board.mode1860Rows() - 1 - from.mode1860Y) + from.mode1860X;
+    std::vector<int> exactTiles = board.reachable1860Tiles(fromTileId, steps);
+    for (int tileId : exactTiles) {
+        const Tile& candidate = board.tileAt(tileId);
+        const int candidateProgress = (board.mode1860Rows() - 1 - candidate.mode1860Y) + candidate.mode1860X;
+        if (candidateProgress >= startProgress) {
+            destinations.push_back(tileId);
+        }
+    }
+
+    const int retirementTile = board.mode1860RetirementTileId();
+    if (board.isMode1860TileId(retirementTile)) {
+        const Tile& retirement = board.tileAt(retirementTile);
+        const int distanceToRetirement = std::abs(from.mode1860Y - retirement.mode1860Y) +
+                                         std::abs(from.mode1860X - retirement.mode1860X);
+        if (distanceToRetirement > 0 && distanceToRetirement <= steps &&
+            std::find(destinations.begin(), destinations.end(), retirementTile) == destinations.end()) {
+            destinations.push_back(retirementTile);
+        }
+    }
+
+    std::sort(destinations.begin(), destinations.end(), [&](int a, int b) {
+        const Tile& tileA = board.tileAt(a);
+        const Tile& tileB = board.tileAt(b);
+        const int progressA = (board.mode1860Rows() - 1 - tileA.mode1860Y) + tileA.mode1860X;
+        const int progressB = (board.mode1860Rows() - 1 - tileB.mode1860Y) + tileB.mode1860X;
+        if (progressA != progressB) {
+            return progressA < progressB;
+        }
+        return a < b;
+    });
+    destinations.erase(std::unique(destinations.begin(), destinations.end()), destinations.end());
+    return destinations;
+}
+
+//Input: reachable tile ids, current cursor tile id, direction row/col delta
+//Output: next cursor tile id
+//Purpose: moves the 1860 movement cursor toward the closest legal tile in that direction
+//Relation: helper for Game::chooseMode1860Destination
+static int chooseNearest1860Cursor(const Board& board,
+                                   const std::vector<int>& reachable,
+                                   int cursorTile,
+                                   int rowDelta,
+                                   int colDelta) {
+    if (reachable.empty() || !board.isMode1860TileId(cursorTile)) {
+        return cursorTile;
+    }
+
+    const Tile& cursor = board.tileAt(cursorTile);
+    int bestTile = cursorTile;
+    int bestScore = 1000000;
+    for (int tileId : reachable) {
+        if (tileId == cursorTile || !board.isMode1860TileId(tileId)) {
+            continue;
+        }
+        const Tile& candidate = board.tileAt(tileId);
+        const int dy = candidate.mode1860Y - cursor.mode1860Y;
+        const int dx = candidate.mode1860X - cursor.mode1860X;
+        if ((rowDelta < 0 && dy >= 0) ||
+            (rowDelta > 0 && dy <= 0) ||
+            (colDelta < 0 && dx >= 0) ||
+            (colDelta > 0 && dx <= 0)) {
+            continue;
+        }
+
+        const int primary = rowDelta != 0 ? std::abs(dy) : std::abs(dx);
+        const int secondary = rowDelta != 0 ? std::abs(dx) : std::abs(dy);
+        const int score = (primary * 100) + secondary;
+        if (score < bestScore || (score == bestScore && tileId < bestTile)) {
+            bestScore = score;
+            bestTile = tileId;
+        }
+    }
+
+    return bestTile;
+}
