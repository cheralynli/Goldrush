+
+        const int totalSteps = steps > 0 ? steps : -steps;
+        int destination = player.tile;
+        if (steps > 0) {
+            destination = isCpuPlayer(playerIndex)
+                ? chooseAutomatic1860Destination(playerIndex, totalSteps)
+                : chooseMode1860Destination(playerIndex, totalSteps);
+        } else {
+            const Tile& from = board.tileAt(player.tile);
+            const int startProgress = (board.mode1860Rows() - 1 - from.mode1860Y) + from.mode1860X;
+            std::vector<int> backwards = board.reachable1860Tiles(player.tile, totalSteps);
+            backwards.erase(std::remove_if(backwards.begin(), backwards.end(), [&](int tileId) {
+                const Tile& candidate = board.tileAt(tileId);
+                const int candidateProgress = (board.mode1860Rows() - 1 - candidate.mode1860Y) + candidate.mode1860X;
+                return candidateProgress > startProgress;
+            }), backwards.end());
+            if (!backwards.empty()) {
+                destination = *std::min_element(backwards.begin(), backwards.end(), [&](int a, int b) {
+                    const Tile& tileA = board.tileAt(a);
+                    const Tile& tileB = board.tileAt(b);
+                    const int progressA = (board.mode1860Rows() - 1 - tileA.mode1860Y) + tileA.mode1860X;
+                    const int progressB = (board.mode1860Rows() - 1 - tileB.mode1860Y) + tileB.mode1860X;
+                    if (progressA != progressB) {
+                        return progressA < progressB;
+                    }
+                    return a < b;
+                });
+            }
+        }
+
+        if (destination == player.tile) {
+            return "No legal 1860 movement destination.";
+        }
+
+        const int startTile = player.tile;
+        const bool stoppedOnSpace = applyMode1860Movement(playerIndex, destination);
+        std::ostringstream out;
+        out << "Moved on the 1860 board from Space " << startTile
+            << " to Space " << player.tile << " - " << getTileDisplayName(board.tileAt(player.tile)) << ".";
+        if (stoppedOnSpace) {
+            out << " STOP resolved.";
+        }
+        return out.str();
+    }
